# Dependencies
node_modules/
**/node_modules/

# Environment files — other .env files stay ignored; backend/.env is tracked (VPS / team workflow).
# If this repo is ever public, remove backend/.env from git and rotate all secrets immediately.
.env
**/.env
!.env.example
!**/.env.example
!backend/.env

# Builds & generated assets
dist/
**/dist/
backend/uploads/

# Logs & caches
*.log
npm-debug.log*
.cache/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
