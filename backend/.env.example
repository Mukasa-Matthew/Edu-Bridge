# Copy to .env in this folder:  cp .env.example .env
# Fill every value before running migrate / dev. Never commit the real .env file.

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=edubridge
PG_USER=postgres
PG_PASSWORD=your_postgres_password

REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=change-me-use-at-least-32-random-characters-in-production
JWT_EXPIRES_IN=7d
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_BYTES=10485760

# Applied by migrate.js (first admin user)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-this-strong-password
ADMIN_SEED_FULL_NAME=Platform Admin
ADMIN_SEED_PHONE=+256700000000

# Demo tutors/students/materials (seed-demo.js)
DEMO_SEED_ENABLED=true
DEMO_SEED_PASSWORD=DemoPassw0rd!

# Email (optional — set EMAIL_ENABLED=false to skip SMTP)
EMAIL_ENABLED=false
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
EMAIL_SENDER_NAME=EduBridge UG
EMAIL_SENDER_WELCOME=noreply@example.com
EMAIL_SENDER_SUPPORT=support@example.com
EMAIL_SENDER_OTP=otp@example.com
